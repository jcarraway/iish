# Database (Railway PostgreSQL)
DATABASE_URL=postgresql://user:password@host:5432/oncovax

# Redis (Railway)
REDIS_URL=redis://default:password@host:6379

# Auth
MAGIC_LINK_SECRET=<64-char-hex-string>

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Resend (email)
RESEND_API_KEY=re_xxxxx
RESEND_FROM_EMAIL=noreply@oncovax.com

# Anthropic (Claude AI)
ANTHROPIC_API_KEY=sk-ant-xxxxx

# Stripe
STRIPE_SECRET_KEY=sk_test_xxxxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx
STRIPE_MONTHLY_PRICE_ID=price_xxxxx
STRIPE_ANNUAL_PRICE_ID=price_xxxxx

# Cloudinary
CLOUDINARY_CLOUD_NAME=xxxxx
CLOUDINARY_API_KEY=xxxxx
CLOUDINARY_API_SECRET=xxxxx

# AWS S3 (medical documents)
AWS_ACCESS_KEY_ID=xxxxx
AWS_SECRET_ACCESS_KEY=xxxxx
AWS_REGION=us-east-1
AWS_S3_BUCKET=oncovax-documents

# Mapbox (geocoding fallback for trial sites)
MAPBOX_ACCESS_TOKEN=pk.xxxxx

# NATS (pipeline orchestration)
NATS_URL=nats://localhost:4222

# AWS S3 (pipeline data)
AWS_S3_PIPELINE_BUCKET=oncovax-pipeline

# AWS Batch (pipeline compute)
AWS_BATCH_JOB_QUEUE_CPU=oncovax-pipeline-cpu-intensive
AWS_BATCH_JOB_QUEUE_STANDARD=oncovax-pipeline-standard
