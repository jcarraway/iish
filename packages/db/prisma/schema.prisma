generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                             String     @id @default(uuid()) @db.Uuid
  email                          String     @unique @map("email")
  name                           String?    @map("name")
  role                           String     @default("patient") @map("role") @db.VarChar(50)
  lastLoginAt                    DateTime?  @map("last_login_at")
  stripeCustomerId               String?    @unique @map("stripe_customer_id")
  subscriptionStatus             String?    @map("subscription_status") @db.VarChar(50)
  subscriptionCurrentPeriodEnd   DateTime?  @map("subscription_current_period_end")
  stripePriceId                  String?    @map("stripe_price_id")
  createdAt                      DateTime   @default(now()) @map("created_at")
  updatedAt                      DateTime   @updatedAt @map("updated_at")

  patient Patient?
  events  UserEvent[]

  @@map("users")
}

model Trial {
  id                  String   @id @default(uuid()) @db.Uuid
  nctId               String   @unique @map("nct_id")
  title               String   @map("title")
  sponsor             String?  @map("sponsor")
  phase               String?  @map("phase") @db.VarChar(50)
  status              String   @map("status") @db.VarChar(50)
  parsedEligibility   Json?    @map("parsed_eligibility")
  rawEligibilityText  String?  @map("raw_eligibility_text")
  interventionName    String?  @map("intervention_name")
  interventionType    String?  @map("intervention_type") @db.VarChar(100)
  interventionDesc    String?  @map("intervention_desc")
  briefSummary        String?  @map("brief_summary")
  lastSyncedAt        DateTime? @map("last_synced_at")
  rawJson             Json?    @map("raw_json")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  sites   TrialSite[]
  matches Match[]

  @@index([status])
  @@map("trials")
}

model TrialSite {
  id        String  @id @default(uuid()) @db.Uuid
  trialId   String  @map("trial_id") @db.Uuid
  facility  String? @map("facility")
  city      String? @map("city")
  state     String? @map("state") @db.VarChar(100)
  country   String? @map("country") @db.VarChar(100)
  lat       Float?  @map("lat")
  lng       Float?  @map("lng")
  contactName  String? @map("contact_name")
  contactEmail String? @map("contact_email")
  contactPhone String? @map("contact_phone")
  createdAt DateTime @default(now()) @map("created_at")

  trial Trial @relation(fields: [trialId], references: [id], onDelete: Cascade)

  @@index([lat, lng])
  @@index([trialId])
  @@map("trial_sites")
}

model Patient {
  id               String   @id @default(uuid()) @db.Uuid
  userId           String   @unique @map("user_id") @db.Uuid
  intakePath       String?  @map("intake_path") @db.VarChar(50)
  profile          Json?    @map("profile")
  fieldSources     Json?    @map("field_sources")
  fieldConfidence  Json?    @map("field_confidence")
  zipCode          String?  @map("zip_code") @db.VarChar(20)
  lat              Float?   @map("lat")
  lng              Float?   @map("lng")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  documents         DocumentUpload[]
  fhirConnections   FhirConnection[]
  matches           Match[]
  financialMatches  FinancialMatch[]
  sequencingOrders  SequencingOrder[]
  genomicResults    GenomicResult[]
  pipelineJobs      PipelineJob[]

  @@map("patients")
}

model DocumentUpload {
  id                String   @id @default(uuid()) @db.Uuid
  patientId         String   @map("patient_id") @db.Uuid
  documentType      String   @map("document_type") @db.VarChar(100)
  s3Key             String?  @map("s3_key")
  s3Bucket          String?  @map("s3_bucket")
  storagePaths      String[] @default([]) @map("storage_paths")
  fileCount         Int      @default(1) @map("file_count")
  mimeType          String?  @map("mime_type") @db.VarChar(100)
  extractionStatus  String   @default("pending") @map("extraction_status") @db.VarChar(50)
  extractionResult  Json?    @map("extraction_result")
  qualityIssues     Json?    @map("quality_issues")
  confidence        Float?   @map("confidence")
  claudeApiCost     Float?   @map("claude_api_cost")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId, createdAt(sort: Desc)])
  @@map("document_uploads")
}

model FhirConnection {
  id                  String    @id @default(uuid()) @db.Uuid
  patientId           String    @map("patient_id") @db.Uuid
  healthSystemId      String?   @map("health_system_id") @db.Uuid
  healthSystemName    String?   @map("health_system_name")
  fhirBaseUrl         String?   @map("fhir_base_url")
  providerSystem      String    @map("provider_system") @db.VarChar(200)
  accessTokenEnc      String?   @map("access_token_enc")
  refreshTokenEnc     String?   @map("refresh_token_enc")
  tokenExpiresAt      DateTime? @map("token_expires_at")
  scopesGranted       String[]  @map("scopes_granted")
  resourcesPulled     Json?     @map("resources_pulled")
  lastSyncedAt        DateTime? @map("last_synced_at")
  syncStatus          String    @default("pending") @map("sync_status") @db.VarChar(50)
  consentGiven        Boolean   @default(false) @map("consent_given")
  consentAt           DateTime? @map("consent_at")
  consentScopes       String[]  @map("consent_scopes")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  patient      Patient       @relation(fields: [patientId], references: [id], onDelete: Cascade)
  healthSystem HealthSystem? @relation(fields: [healthSystemId], references: [id])

  @@index([patientId])
  @@map("fhir_connections")
}

model HealthSystem {
  id              String   @id @default(uuid()) @db.Uuid
  name            String
  fhirBaseUrl     String   @map("fhir_base_url")
  brand           String?
  logoUrl         String?  @map("logo_url")
  city            String?
  state           String?  @db.VarChar(100)
  isCancerCenter  Boolean  @default(false) @map("is_cancer_center")
  ehrVendor       String   @default("epic") @map("ehr_vendor") @db.VarChar(50)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  fhirConnections FhirConnection[]

  @@index([name])
  @@index([state])
  @@map("health_systems")
}

model Match {
  id                String   @id @default(uuid()) @db.Uuid
  patientId         String   @map("patient_id") @db.Uuid
  trialId           String   @map("trial_id") @db.Uuid
  matchScore        Float    @map("match_score")
  matchBreakdown    Json?    @map("match_breakdown")
  potentialBlockers Json?    @map("potential_blockers")
  status            String   @default("new") @map("status") @db.VarChar(50)
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  trial   Trial   @relation(fields: [trialId], references: [id], onDelete: Cascade)

  @@unique([patientId, trialId])
  @@index([patientId, matchScore(sort: Desc)])
  @@map("matches")
}

model FinancialProgram {
  id                    String   @id @default(uuid()) @db.Uuid
  name                  String
  organization          String
  type                  String   @db.VarChar(50)
  assistanceCategories  String[] @map("assistance_categories")
  description           String?
  maxBenefitAmount      Float?   @map("max_benefit_amount")
  benefitDescription    String?  @map("benefit_description")
  eligibility           Json     @map("eligibility")
  status                String   @default("unknown") @db.VarChar(50)
  statusUrl             String?  @map("status_url")
  lastStatusCheck       DateTime? @map("last_status_check")
  applicationProcess    String?  @map("application_process") @db.VarChar(50)
  applicationUrl        String?  @map("application_url")
  applicationPhone      String?  @map("application_phone")
  requiredDocuments     String[] @map("required_documents")
  turnaroundTime        String?  @map("turnaround_time")
  phone                 String?
  website               String
  email                 String?
  hours                 String?
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  matches FinancialMatch[]

  @@index([type])
  @@index([status])
  @@map("financial_programs")
}

model FinancialMatch {
  id              String   @id @default(uuid()) @db.Uuid
  patientId       String   @map("patient_id") @db.Uuid
  programId       String   @map("program_id") @db.Uuid
  matchStatus     String   @map("match_status") @db.VarChar(50)
  estimatedBenefit String?  @map("estimated_benefit")
  matchReasoning  String?  @map("match_reasoning")
  missingInfo     Json?    @map("missing_info")
  status          String   @default("new") @db.VarChar(50)
  appliedAt       DateTime? @map("applied_at")
  notifyOnReopen  Boolean  @default(false) @map("notify_on_reopen")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  patient  Patient          @relation(fields: [patientId], references: [id], onDelete: Cascade)
  program  FinancialProgram @relation(fields: [programId], references: [id], onDelete: Cascade)

  @@unique([patientId, programId])
  @@index([patientId, matchStatus])
  @@map("financial_matches")
}

model SequencingProvider {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  type        String   @db.VarChar(50)
  testTypes   String[] @map("test_types")
  details     Json     @map("details")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  orders SequencingOrder[]

  @@index([type])
  @@map("sequencing_providers")
}

model SequencingOrder {
  id                  String   @id @default(uuid()) @db.Uuid
  patientId           String   @map("patient_id") @db.Uuid
  providerId          String   @map("provider_id") @db.Uuid
  testType            String   @map("test_type") @db.VarChar(100)
  status              String   @default("pending") @map("status") @db.VarChar(50)
  insuranceCoverage   Json?    @map("insurance_coverage")
  lomnContent         String?  @map("lomn_content")
  results             Json?    @map("results")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  patient        Patient            @relation(fields: [patientId], references: [id], onDelete: Cascade)
  provider       SequencingProvider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  genomicResult  GenomicResult?
  pipelineJobs   PipelineJob[]

  @@index([patientId, createdAt(sort: Desc)])
  @@index([providerId])
  @@map("sequencing_orders")
}

model InsuranceCoverageRule {
  id              String   @id @default(uuid()) @db.Uuid
  insurer         String   @db.VarChar(100)
  testType        String   @map("test_type") @db.VarChar(100)
  cancerType      String?  @map("cancer_type") @db.VarChar(200)
  stage           String?  @db.VarChar(50)
  coverageStatus  String   @map("coverage_status") @db.VarChar(50)
  conditions      String[] @map("conditions")
  cptCodes        String[] @map("cpt_codes")
  sourceUrl       String?  @map("source_url")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@index([insurer, testType])
  @@map("insurance_coverage_rules")
}

model UserEvent {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  event     String   @db.VarChar(100)
  metadata  Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([event, createdAt])
  @@map("user_events")
}

model GenomicResult {
  id                    String    @id @default(uuid()) @db.Uuid
  patientId             String    @map("patient_id") @db.Uuid
  orderId               String?   @unique @map("order_id") @db.Uuid
  documentUploadId      String?   @map("document_upload_id") @db.Uuid
  source                String    @db.VarChar(50)
  provider              String
  testName              String    @map("test_name")
  reportDate            DateTime? @map("report_date")
  specimenDate          DateTime? @map("specimen_date")
  alterations           Json      @map("alterations")
  biomarkers            Json      @map("biomarkers")
  germlineFindings      Json?     @map("germline_findings")
  reportTherapyMatches  Json?     @map("report_therapy_matches")
  interpretation        Json?     @map("interpretation")
  interpretationAt      DateTime? @map("interpretation_at")
  patientConfirmed      Boolean   @default(false) @map("patient_confirmed")
  extractionConfidence  Float?    @map("extraction_confidence")
  matchDelta            Json?     @map("match_delta")
  rematchedAt           DateTime? @map("rematched_at")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  patient Patient          @relation(fields: [patientId], references: [id], onDelete: Cascade)
  order   SequencingOrder? @relation(fields: [orderId], references: [id])

  @@index([patientId, createdAt(sort: Desc)])
  @@map("genomic_results")
}

model PipelineJob {
  id                    String    @id @default(uuid()) @db.Uuid
  patientId             String    @map("patient_id") @db.Uuid
  sequencingOrderId     String?   @map("sequencing_order_id") @db.Uuid
  tumorDataPath         String    @map("tumor_data_path")
  normalDataPath        String    @map("normal_data_path")
  rnaDataPath           String?   @map("rna_data_path")
  inputFormat           String    @map("input_format") @db.VarChar(20)
  referenceGenome       String    @default("GRCh38") @map("reference_genome") @db.VarChar(20)
  status                String    @default("queued") @map("status") @db.VarChar(20)
  currentStep           String?   @map("current_step") @db.VarChar(50)
  stepsCompleted        String[]  @default([]) @map("steps_completed")
  stepErrors            Json?     @map("step_errors")
  retryCount            Int       @default(0) @map("retry_count")
  maxRetries            Int       @default(3) @map("max_retries")
  alignedBamPath        String?   @map("aligned_bam_path")
  vcfPath               String?   @map("vcf_path")
  annotatedVcfPath      String?   @map("annotated_vcf_path")
  peptideFilePath       String?   @map("peptide_file_path")
  variantCount          Int?      @map("variant_count")
  tmb                   Float?    @map("tmb")
  hlaGenotype           Json?     @map("hla_genotype")
  neoantigenCount       Int?      @map("neoantigen_count")
  topNeoantigens        Json?     @map("top_neoantigens")
  vaccineBlueprint      Json?     @map("vaccine_blueprint")
  neoantigenReportPath  String?   @map("neoantigen_report_path")
  vaccineBlueprintPath  String?   @map("vaccine_blueprint_path")
  fullReportPdfPath     String?   @map("full_report_pdf_path")
  patientSummaryPath    String?   @map("patient_summary_path")
  totalComputeSeconds   Int?      @map("total_compute_seconds")
  estimatedCostUsd      Float?    @map("estimated_cost_usd")
  startedAt             DateTime? @map("started_at")
  completedAt           DateTime? @map("completed_at")
  estimatedCompletion   DateTime? @map("estimated_completion")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  patient          Patient              @relation(fields: [patientId], references: [id], onDelete: Cascade)
  sequencingOrder  SequencingOrder?     @relation(fields: [sequencingOrderId], references: [id])
  neoantigens      NeoantigenCandidate[]

  @@index([patientId, createdAt(sort: Desc)])
  @@index([status])
  @@map("pipeline_jobs")
}

model NeoantigenCandidate {
  id                      String  @id @default(uuid()) @db.Uuid
  jobId                   String  @map("job_id") @db.Uuid
  gene                    String  @map("gene")
  mutation                String  @map("mutation")
  chromosome              String  @map("chromosome") @db.VarChar(10)
  position                Int     @map("position")
  refAllele               String  @map("ref_allele")
  altAllele               String  @map("alt_allele")
  variantType             String  @map("variant_type") @db.VarChar(30)
  vaf                     Float   @map("vaf")
  wildtypePeptide         String  @map("wildtype_peptide")
  mutantPeptide           String  @map("mutant_peptide")
  peptideLength           Int     @map("peptide_length")
  hlaAllele               String  @map("hla_allele") @db.VarChar(30)
  bindingAffinityNm       Float   @map("binding_affinity_nm")
  bindingRankPercentile   Float   @map("binding_rank_percentile")
  wildtypeBindingNm       Float?  @map("wildtype_binding_nm")
  bindingClass            String  @map("binding_class") @db.VarChar(20)
  immunogenicityScore     Float   @map("immunogenicity_score")
  agretopicity            Float   @map("agretopicity")
  expressionLevel         Float?  @map("expression_level")
  clonality               Float   @map("clonality")
  structurePdbPath        String? @map("structure_pdb_path")
  structuralExposure      Float?  @map("structural_exposure")
  compositeScore          Float   @map("composite_score")
  rank                    Int     @map("rank")
  confidence              String  @map("confidence") @db.VarChar(20)
  details                 Json    @map("details")
  createdAt               DateTime @default(now()) @map("created_at")

  job PipelineJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId, rank])
  @@index([gene])
  @@map("neoantigen_candidates")
}
