  interpretation        Json?
  documentUploadId      String?   @map("document_upload_id") @db.Uuid
  triggeredTrialRematch Boolean   @default(false) @map("triggered_trial_rematch")
  createdAt             DateTime  @default(now()) @map("created_at")

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId, testDate(sort: Desc)])
  @@map("ctdna_results")
}

model NotificationLog {
  id            String   @id @default(uuid()) @db.Uuid
  patientId     String   @map("patient_id") @db.Uuid
  category      String   @db.VarChar(50)
  channel       String   @default("email") @db.VarChar(20)
  subject       String?
  referenceId   String?  @map("reference_id") @db.Uuid
  referenceType String?  @map("reference_type") @db.VarChar(50)
  dedupeKey     String?  @map("dedupe_key")
  sentAt        DateTime @default(now()) @map("sent_at")

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId, category, sentAt(sort: Desc)])
  @@index([dedupeKey])
  @@map("notification_logs")
}

model NotificationPreference {
  id                      String   @id @default(uuid()) @db.Uuid
  patientId               String   @unique @map("patient_id") @db.Uuid
  surveillanceReminders   Boolean  @default(true) @map("surveillance_reminders")
  journalReminders        Boolean  @default(true) @map("journal_reminders")
  weeklySummary           Boolean  @default(true) @map("weekly_summary")
  appointmentPrep         Boolean  @default(true) @map("appointment_prep")
  ctdnaResults            Boolean  @default(true) @map("ctdna_results")
  scpAnnualReview         Boolean  @default(true) @map("scp_annual_review")
  lifestyleCheckIn        Boolean  @default(true) @map("lifestyle_check_in")
  phaseTransitions        Boolean  @default(true) @map("phase_transitions")
  quietHoursStart         String?  @map("quiet_hours_start") @db.VarChar(5)
  quietHoursEnd           String?  @map("quiet_hours_end") @db.VarChar(5)
  timezone                String   @default("America/New_York") @db.VarChar(50)
  createdAt               DateTime @default(now()) @map("created_at")
  updatedAt               DateTime @updatedAt @map("updated_at")

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@map("notification_preferences")
}

model SurvivorshipFeedback {
  id           String   @id @default(uuid()) @db.Uuid
  patientId    String   @map("patient_id") @db.Uuid
  feedbackType String   @map("feedback_type") @db.VarChar(50)
  rating       Int?
  comment      String?
  context      Json?
  createdAt    DateTime @default(now()) @map("created_at")

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId, feedbackType])
  @@map("survivorship_feedback")
}

model RecurrenceEvent {
  id                    String    @id @default(uuid()) @db.Uuid
  patientId             String    @map("patient_id") @db.Uuid
  detectedDate          DateTime  @map("detected_date")
  detectionMethod       String    @map("detection_method") @db.VarChar(30)
  recurrenceType        String?   @map("recurrence_type") @db.VarChar(20)
  recurrenceSites       String[]  @default([]) @map("recurrence_sites")
  confirmedByBiopsy     Boolean   @default(false) @map("confirmed_by_biopsy")
  newPathologyAvailable Boolean   @default(false) @map("new_pathology_available")
  newStage              String?   @map("new_stage") @db.VarChar(20)
  newBiomarkers         Json?     @map("new_biomarkers")
  timeSinceInitialDx    Int?      @map("time_since_initial_dx")
  timeSinceCompletion   Int?      @map("time_since_completion")
  ctdnaResultId         String?   @map("ctdna_result_id") @db.Uuid
  priorTreatments       String[]  @default([]) @map("prior_treatments")
  documentUploadId      String?   @map("document_upload_id") @db.Uuid
  cascadeStatus         Json      @default("{}") @map("cascade_status")
  acknowledgedAt        DateTime? @map("acknowledged_at")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId, createdAt(sort: Desc)])
  @@map("recurrence_events")
}
