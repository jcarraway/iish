model FeedRelevance {
  id               String       @id @default(cuid()) @map("id")
  userId           String       @map("user_id") @db.Uuid
  itemId           String       @map("item_id") @db.Uuid
  relevanceScore   Int          @default(0) @map("relevance_score")
  personalizedNote String?      @map("personalized_note")
  viewed           Boolean      @default(false) @map("viewed")
  viewedAt         DateTime?    @map("viewed_at")
  saved            Boolean      @default(false) @map("saved")
  dismissed        Boolean      @default(false) @map("dismissed")
  shared           Boolean      @default(false) @map("shared")
  createdAt        DateTime     @default(now()) @map("created_at")
  updatedAt        DateTime     @updatedAt @map("updated_at")

  user             User         @relation(fields: [userId], references: [id])
  item             ResearchItem @relation(fields: [itemId], references: [id])

  @@unique([userId, itemId])
  @@index([userId, relevanceScore(sort: Desc)])
  @@index([userId, dismissed])
  @@map("feed_relevance")
}

